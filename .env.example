# ================================================================
# Clipla Backend — Environment Variables
# Bu dosyayı kopyalayın: cp .env.example .env
# Gerçek değerleri .env dosyasına girin (.gitignore'a ekli olmalı)
# ================================================================

# ── Anthropic (zorunlu) ─────────────────────────────────────────
# Claude ile chat + altyazı çevirisi için gerekli
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (zorunlu) ───────────────────────────────────────────
# Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API Kimlik Doğrulama ─────────────────────────────────────────
# Tüm /api/* endpoint'leri için Bearer token zorunludur.
# Birden fazla key virgülle ayrılır. Boş bırakılırsa dev modunda çalışır.
# Güvenli key üretmek için: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=clipla-dev-key-degistir

# Pro özelliklere (effects, shorts) erişecek key'ler (virgülle ayrılır)
# Bu listedeki key'ler get_plan_from_request() ile 'pro' planı alır
PRO_API_KEYS=clipla-pro-key-degistir

# ── IP Anonimleştirme ────────────────────────────────────────────
# Analytics loglarında ham IP yerine HMAC hash kullanılır (KVKK/GDPR)
# Rastgele bir salt üretin: python -c "import secrets; print(secrets.token_hex(32))"
IP_HASH_SALT=clipla-ip-salt-2026-degistir

# ── CORS ─────────────────────────────────────────────────────────
# Production'da uygulamanızın domain'ini yazın
# Birden fazla: https://app.clipla.com,https://www.clipla.com
# Expo/React Native: exp:// veya https:// scheme gerekebilir
# Geliştirme için: *
CORS_ORIGINS=https://app.clipla.com

# ── Production URL ───────────────────────────────────────────────
# Backend'in erişilebilir public URL'i (output_url'lerde kullanılır)
# Railway örneği: https://clipla-backend.up.railway.app
# Render örneği:  https://clipla-api.onrender.com
PUBLIC_BASE_URL=https://api.clipla.com

# ── STT: Whisper ─────────────────────────────────────────────────
# Ses-den-metne dönüşüm için Whisper kullanılır (yerel, internet gerektirmez)
# Kullanılabilir modeller: tiny | base | small | medium | large-v3
# Sunucu RAM'i az ise: tiny veya base önerilir
# Production önerisi: small (iyi denge)
WHISPER_MODEL=small

# ── Claude Transcript İyileştirme ────────────────────────────────
# true  → Whisper transkripti Claude ile iyileştirilir (ANTHROPIC_API_KEY gerektirir)
# false → ham Whisper çıktısı kullanılır
CLAUDE_ENHANCE=true
CLAUDE_ENHANCE_MODEL=claude-haiku-4-5-20251001

# ── Upload Limiti ────────────────────────────────────────────────
# Sunucu tarafı maksimum dosya boyutu (MB cinsinden)
MAX_UPLOAD_MB=800

# ── LibreTranslate (opsiyonel) ───────────────────────────────────
# Self-hosted LibreTranslate kuruluysa altyazı çevirisi için kullanılır.
# Ayarlanmazsa Anthropic API'ye (ANTHROPIC_API_KEY) düşülür.
LIBRETRANSLATE_URL=

# ── Admin ────────────────────────────────────────────────────────
# Admin paneli: Authorization: Bearer <bu_değer>
CLIPLA_ADMIN_PASSWORD=clipla2026-degistir
